[Unit]
Description=Production Dashboard TV
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=sameng
WorkingDirectory=/home/sameng/production-dashboard-tv
EnvironmentFile=/home/sameng/production-dashboard-tv/dashboard.env
ExecStart=/usr/bin/python3 -u /home/sameng/production-dashboard-tv/server.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
